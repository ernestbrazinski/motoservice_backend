# Copy to .env and adjust. Used by docker-compose and (optionally) the Nest app.
PORT=3030

# Allowed browser origins (comma-separated). If unset, any Origin is echoed in dev.
# Example: CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# CORS_ORIGINS=http://localhost:3000

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=motoservice
DATABASE_PASSWORD=motoservice
DATABASE_NAME=motoservice

# If the users table is empty on startup, a superadmin is created once (plain password is hashed with bcrypt).
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me

# JWT for POST /auth/login (use a long random secret in production).
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
